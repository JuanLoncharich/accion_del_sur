# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=accion_del_sur
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Stellar (preparado para integración futura)
STELLAR_NETWORK=testnet
STELLAR_PUBLIC_KEY=
STELLAR_SECRET_KEY=

# Uploads
UPLOADS_PATH=uploads

# Email SMTP (notificaciones al donante)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_o_app_password
SMTP_FROM="Accion del Sur <tu_correo@gmail.com>"
